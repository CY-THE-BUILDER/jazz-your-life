generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SiteLocale {
  zh_Hant
  en
}

enum PageType {
  LANDING
  PROJECT
  ESSAY
  LAB
  ABOUT
}

enum ProjectStatus {
  DRAFT
  LIVE
  ARCHIVED
}

enum SectionKind {
  HERO
  STATEMENT
  PROJECT_GRID
  ICON_SHOWCASE
  ESSAY_LIST
  CTA
  CUSTOM
}

enum BlockKind {
  RICH_TEXT
  METRIC
  QUOTE
  LINK
  IMAGE
  ICON
  TAG_LIST
  CUSTOM
}

enum AssetKind {
  IMAGE
  SVG
  VIDEO
  AUDIO
  DOCUMENT
}

model Brand {
  id            String         @id @default(cuid())
  slug          String         @unique
  defaultLocale SiteLocale     @default(zh_Hant)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  locales       BrandLocale[]
  sites         Site[]
  themeTokens   ThemeToken[]
  icons         BrandIcon[]
  assets        Asset[]
}

model BrandLocale {
  id          String     @id @default(cuid())
  brandId     String
  locale      SiteLocale
  name        String
  tagline     String?
  description String?
  brand       Brand      @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, locale])
}

model Site {
  id              String           @id @default(cuid())
  brandId         String
  slug            String
  domain          String           @unique
  isPrimary       Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  brand           Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  pages           Page[]
  projects        Project[]
  navigationItems NavigationItem[]

  @@unique([brandId, slug])
}

model Page {
  id           String        @id @default(cuid())
  siteId       String
  slug         String
  pageType     PageType
  isPublished  Boolean       @default(false)
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  site         Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sections     Section[]
  locales      PageLocale[]
  seoMeta      SeoMeta?

  @@unique([siteId, slug])
}

model PageLocale {
  id            String     @id @default(cuid())
  pageId        String
  locale        SiteLocale
  title         String
  description   String?
  socialTitle   String?
  socialSummary String?
  page          Page       @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
}

model Section {
  id         String        @id @default(cuid())
  pageId     String
  key        String
  kind       SectionKind
  orderIndex Int
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  page       Page          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  locales    SectionLocale[]
  blocks     Block[]

  @@unique([pageId, key])
  @@unique([pageId, orderIndex])
}

model SectionLocale {
  id        String     @id @default(cuid())
  sectionId String
  locale    SiteLocale
  eyebrow   String?
  title     String?
  body      String?
  section   Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, locale])
}

model Block {
  id         String        @id @default(cuid())
  sectionId  String
  key        String
  kind       BlockKind
  orderIndex Int
  payload    Json
  section    Section       @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  locales    BlockLocale[]

  @@unique([sectionId, key])
  @@unique([sectionId, orderIndex])
}

model BlockLocale {
  id      String     @id @default(cuid())
  blockId String
  locale  SiteLocale
  label   String?
  title   String?
  body    String?
  block   Block      @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, locale])
}

model Project {
  id         String               @id @default(cuid())
  siteId     String
  slug       String
  status     ProjectStatus        @default(DRAFT)
  path       String
  sortOrder  Int                  @default(0)
  launchedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  site       Site                 @relation(fields: [siteId], references: [id], onDelete: Cascade)
  locales    ProjectLocale[]
  tags       ProjectTagOnProject[]
  links      ProjectLink[]
  metrics    ProjectMetric[]
  releases   ProjectRelease[]

  @@unique([siteId, slug])
}

model ProjectLocale {
  id          String      @id @default(cuid())
  projectId   String
  locale      SiteLocale
  name        String
  summary     String
  description String?
  role        String?
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
}

model ProjectTag {
  id       String               @id @default(cuid())
  slug     String               @unique
  projects ProjectTagOnProject[]
}

model ProjectTagOnProject {
  projectId String
  tagId     String
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       ProjectTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([projectId, tagId])
}

model ProjectLink {
  id         String   @id @default(cuid())
  projectId  String
  label      String
  href       String
  isPrimary  Boolean  @default(false)
  orderIndex Int      @default(0)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectMetric {
  id         String   @id @default(cuid())
  projectId  String
  key        String
  value      String
  orderIndex Int      @default(0)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectRelease {
  id        String   @id @default(cuid())
  projectId String
  version   String
  releaseAt DateTime
  notes     String?
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Asset {
  id       String         @id @default(cuid())
  brandId  String
  kind     AssetKind
  slug     String         @unique
  alt      String?
  brand    Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  variants AssetVariant[]
}

model AssetVariant {
  id      String   @id @default(cuid())
  assetId String
  format  String
  width   Int?
  height  Int?
  url     String
  asset   Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model ThemeToken {
  id       String             @id @default(cuid())
  brandId  String
  category String
  token    String
  value    String
  brand    Brand              @relation(fields: [brandId], references: [id], onDelete: Cascade)
  locales  ThemeTokenLocale[]

  @@unique([brandId, category, token])
}

model ThemeTokenLocale {
  id           String      @id @default(cuid())
  themeTokenId String
  locale       SiteLocale
  label        String
  description  String?
  themeToken   ThemeToken  @relation(fields: [themeTokenId], references: [id], onDelete: Cascade)

  @@unique([themeTokenId, locale])
}

model BrandIcon {
  id       String             @id @default(cuid())
  brandId  String
  slug     String
  isActive Boolean            @default(false)
  brand    Brand              @relation(fields: [brandId], references: [id], onDelete: Cascade)
  versions BrandIconVersion[]

  @@unique([brandId, slug])
}

model BrandIconVersion {
  id          String     @id @default(cuid())
  brandIconId String
  version     Int
  svgSource   String
  notes       String?
  createdAt   DateTime   @default(now())
  brandIcon   BrandIcon  @relation(fields: [brandIconId], references: [id], onDelete: Cascade)

  @@unique([brandIconId, version])
}

model SeoMeta {
  id             String  @id @default(cuid())
  pageId         String  @unique
  canonicalUrl   String?
  ogImageAssetId String?
  robots         String?
  page           Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model NavigationItem {
  id         String   @id @default(cuid())
  siteId     String
  label      String
  href       String
  orderIndex Int      @default(0)
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
}
